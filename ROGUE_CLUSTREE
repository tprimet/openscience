# Plage de résolution à tester avec ROGUE 0-0.4

# Calcul de la meilleure résolution avec ROGUE
seurat_rogue <- seurat_obj
seurat_rogue <- NormalizeData(seurat_rogue)
seurat_rogue <- FindVariableFeatures(seurat_rogue)
seurat_rogue <- ScaleData(seurat_rogue)
seurat_rogue <- RunPCA(seurat_rogue)
seurat_rogue <- FindNeighbors(seurat_rogue, dims = 1:30)

resolutions_seurat_rogue <- seq(0, 0.4, by = 0.05)

rogue_scores_seurat_rogue <- list()

for (res in resolutions_seurat_rogue) {
  
  tmp <- FindClusters(seurat_rogue, resolution = res)
  
  expr <- as.matrix(GetAssayData(tmp, layer = "counts"))
  
  clusters <- Idents(tmp)
  
  samples <- rep("sample1", ncol(expr))
  
  rogue_res <- rogue(expr, labels = clusters, samples = samples, platform = "UMI")
  
  rogue_scores_seurat_rogue[[as.character(res)]] <- rogue_res
}

rogue_mean_seurat_rogue <- numeric(length(rogue_scores_seurat_rogue))
names(rogue_mean_seurat_rogue) <- names(rogue_scores_seurat_rogue)

for (i in 1:length(rogue_scores_seurat_rogue)) {
  rogue_mean_seurat_rogue[i] <- mean(as.numeric(rogue_scores_seurat_rogue[[i]]))
}

res_seurat_rogue <- as.numeric(names(rogue_mean_seurat_rogue))

data.frame(
  resolution = res_seurat_rogue,
  rogue      = rogue_mean_seurat_rogue
) |>
  ggplot(aes(x = resolution, y = rogue)) +
  geom_line(colour = "darkgreen", linewidth = 0.8) +
  geom_point(colour = "darkgreen", size = 3) +
  scale_x_continuous(breaks = res_seurat_rogue) +
  labs(x = "Résolutions", y = "Score ROGUE moyen") +
  theme_classic() +
  theme(
    axis.title  = element_text(size = 12, face = "bold"),
    axis.text   = element_text(size = 10),
    axis.line   = element_line(colour = "grey40"),
    axis.ticks  = element_line(colour = "grey40"),
    panel.grid.major.y = element_line(colour = "grey90", linetype = "dashed")
  )


