library(Matrix)
library(Seurat)
library(umap)
library(ggplot2)
library(magrittr)
library(dplyr)
library(patchwork)
library(ggpubr)
library(tidyr)

# Chargement des données et création de l'objet seurat
mtx_file <- "/Users/timotheeprimet/Desktop/ENS/1A/ImmEx/open science/mat/matrix.mtx"
barcodes <- "/Users/timotheeprimet/Desktop/ENS/1A/ImmEx/open science/mat/barcodes.tsv"
features <- "/Users/timotheeprimet/Desktop/ENS/1A/ImmEx/open science/mat/features.tsv"
metadata_file <- "/Users/timotheeprimet/Desktop/ENS/1A/ImmEx/open science/GSE233236_metadata.tsv"

counts <- ReadMtx(mtx = mtx_file,cells = barcodes,features = features,feature.column = 1)
metadata <- read.table(metadata_file,sep = "\t",header = TRUE,row.names = 1,check.names = FALSE)
seurat_full <- CreateSeuratObject(counts = counts)

# ajouter les métadonnées dans le même ordre
seurat_full <- AddMetaData(seurat_full,metadata = metadata[colnames(seurat_full), , drop = FALSE])

# Quality control et filtre immunoglobulines
seurat_full[["percent.mt"]] <- PercentageFeatureSet(seurat_full, pattern = "^MT-")
seurat_full <- subset(seurat_full,subset = nFeature_RNA > 400 & percent.mt < 20)
patterns_IG <- "^IG[HKL]"
genes_to_remove_IG <- grep(patterns_IG, rownames(seurat_full), value = TRUE)
seurat_full <- seurat_full[!rownames(seurat_full) %in% genes_to_remove_IG,]

# Normalisation et sélection des HVG
seurat_full <- NormalizeData(seurat_full)
seurat_full <- FindVariableFeatures(seurat_full, nfeatures = 2000)
#Filtration des gènes de bruis parmi les HVG
patterns_noise <- c("^RPS", "^RPL", "^MT-", "^MRPS", "^MRPL", "^HSP")
genes_to_remove_noise <- grep(paste(patterns_noise, collapse = "|"),VariableFeatures(seurat_full),value = TRUE)
VariableFeatures(seurat_full) <- setdiff(
  VariableFeatures(seurat_full),
  genes_to_remove_noise
)

# Réduction de dimension
seurat_full <- ScaleData(seurat_full)
seurat_full <- RunPCA(seurat_full, features=VariableFeatures((seurat_full)))

# PREMIER CLUSTERING
seurat_full <- FindNeighbors(seurat_full, dims = 1:30)


# la clustree et ROGUE

seurat_full<- FindClusters(seurat_full, resolution = 0.2)
seurat_full <- RunUMAP(seurat_full, dims = 1:30, umap.method = "uwot")

DimPlot(seurat_full, label = TRUE)

#Annotation avec les marqueurs

Idents(seurat_full) <- "seurat_clusters"
marker_genes <- c("TCL1A","CD27", "TNFRSF13B", "AICDA", "BCL6", "MKI67","MZB1")
DotPlot(seurat_full, features = marker_genes) + RotatedAxis() + scale_color_gradient2(low = "blue", mid = "white", high = "red")
FeaturePlot(seurat_full, features = marker_genes, reduction = "umap")
Idents(seurat_full) <- "seurat_clusters"

# Annotation visuelle en fonction de Dot plot et feature plot 
seurat_full <- RenameIdents(
  seurat_full,
  "0" = "Bm cells",
  "1" = "ASC",
  "2" = "ASC",
  "3" = "Bn cells",
  "4" = "Bgc cells",
  "5" = "Bn cells",
  "6" = "B cycling",
  "7" = "ASC"
)
seurat_full$celltype <- Idents(seurat_full)

DimPlot(seurat_full, group.by = "celltype", label = TRUE) + ggtitle("Cell types annotés")
DimPlot(seurat_full, group.by = "seurat_clusters", label = TRUE) + ggtitle("Clusters initiaux")

DotPlot(seurat_full, features = marker_genes, group.by = "celltype") + RotatedAxis()
FeaturePlot(seurat_full, features = marker_genes, reduction = "umap")


# DEUXIEME CLUSTERING : clustering de chaque lignée 

lignees <- c("Bn cells", "Bm cells", "Bgc cells", "B cycling", "ASC")

resolutions <- c(
  "Bn cells"   = 0.05,
  "Bm cells"   = 0.55,
  "Bgc cells"  = 0.05,
  "B cycling"  = 0.1,
  "ASC"        = 0.2
)

seurat_sub_full <- list()
subcluster_markers_noIG <- list()    # résultats complets FindAllMarkers
top50_markers_noIG <- list()         # top 50 gènes par sous-cluster 
plots_dim <- list()
plots_dot_top_noIG <- list()


cat("\nCelltypes disponibles dans seurat_cluster :\n")
print(table(seurat_full$celltype, useNA = "ifany"))

for (lignee in lignees) {
  cat("Sous-clustering :", lignee, "\n")
  

  # Sélection des cellules de la lignée
  cells_lignee <- colnames(seurat_full)[seurat_full$celltype == lignee]
  sub_cluster <- subset(seurat_full, cells = cells_lignee)

  # Sous-clustering 
  sub_cluster <- NormalizeData(sub_cluster)
  sub_cluster <- FindVariableFeatures(sub_cluster, nfeatures = 1000)
  sub_cluster <- ScaleData(sub_cluster)
  sub_cluster <- RunPCA(sub_cluster)
  sub_cluster <- FindNeighbors(sub_cluster, dims = 1:30)
  sub_cluster <- FindClusters(sub_cluster,resolution = resolutions[[lignee]])
  sub_cluster <- RunUMAP(sub_cluster,dims = 1:30,umap.method = "uwot")
  
  Idents(sub_cluster) <- "seurat_clusters"
  
  seurat_sub_full[[lignee]] <- sub_cluster
  
  
  # FindAllMarkers (Wilcoxon)(comme dans tableau S3)
  # pour min.pct je sais pas
  markers_noIG <- FindAllMarkers(sub_cluster,min.pct=0.25,logfc.threshold=0.25,test.use="wilcox")
  subcluster_markers_noIG[[lignee]] <- markers_noIG
  
  # top 50 gènes par sous-cluster
  top50_noIG <- markers_noIG %>%group_by(cluster) %>%filter(p_val_adj<0.05)%>%arrange(desc(avg_log2FC), by_group=TRUE)%>%slice_head(n=50)%>%ungroup()
  top50_markers_noIG[[lignee]] <- top50_noIG
  
  # DimPlot
  p_dim <- DimPlot(sub_cluster, label = TRUE) + ggtitle(paste("Sous-clustering -", lignee))
  
  plots_dim[[lignee]] <- p_dim
  print(p_dim)
  
  # DotPlot des top 5 marqueurs (on stocke top 50, mais on affiche top 5 pour la lisibilité)
  if (nrow(top50_noIG) > 0) {
    top5_genes_noIG <- top50_noIG %>%
      group_by(cluster) %>%
      slice_max(order_by = avg_log2FC, n = 5, with_ties = FALSE) %>%
      pull(gene) %>%
      unique()
    
    top5_genes_noIG_present <- top5_genes_noIG[top5_genes_noIG %in% rownames(sub_cluster)]
    
    if (length(top5_genes_noIG_present) > 0) {
      p_dot_top_noIG <- DotPlot(sub_cluster, features = top5_genes_noIG_present) +
        RotatedAxis() +
        ggtitle(paste("Top 5 marqueurs -", lignee))
      
      plots_dot_top_noIG[[lignee]] <- p_dot_top_noIG
      print(p_dot_top_noIG)
    }
  }
}
